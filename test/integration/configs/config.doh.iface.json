{
  "driver": {
    "driver_dir": "__DRIVER_DIR__",
    "auto_discover": true,
    "load": []
  },
  "resolver": {
    "use_custom_server": true,
    "servers": [
      {"address": "https://127.0.0.1:1443/dns-query", "port": 1443}
    ]
  },
  "domains": [
    {
      "name": "yaddnsc.test",
      "update_interval": 60,
      "force_update": 0,
      "driver": "simple",
      "subdomains": [
        {
          "name": "iface",
          "type": "a",
          "ip_source": "interface",
          "ip_type": "ipv4",
          "interface": "lo",
          "driver_param": {
            "url": "http://127.0.0.1:8080/update?ip={ip_addr}&domain={domain}&source=iface&resolver=doh"
          }
        }
      ]
    }
  ]
}
