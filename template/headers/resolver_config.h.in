#ifndef YADDNSC_RESOLVER_CONFIG_H
#define YADDNSC_RESOLVER_CONFIG_H

// Whether to use the built-in DNS stack instead of the system libresolv.
//   0 = system libresolv (res_mkquery / res_nquery), 1 = built-in.
//
// The #ifndef guard lets test targets override this via compile definition
// (e.g. -DYADDNSC_USE_NATIVE_DNS=1 for native-backend tests) without
// triggering -Werror redefinition warnings.
#ifndef YADDNSC_USE_NATIVE_DNS
#cmakedefine01 YADDNSC_USE_NATIVE_DNS
#endif

// Default DNS server address and port when none is configured.
#define YADDNSC_DEFAULT_DNS_SERVER "@YADDNSC_DEFAULT_DNS_SERVER@"
#define YADDNSC_DEFAULT_DNS_PORT @YADDNSC_DEFAULT_DNS_PORT@

#endif // YADDNSC_RESOLVER_CONFIG_H
