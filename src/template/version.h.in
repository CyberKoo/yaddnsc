#ifndef YADDNSC_VERSION_H
#define YADDNSC_VERSION_H

#include <string_view>

namespace yaddnsc {
    constexpr auto YADDNSC_VERSION_MAJOR = "@YADDNSC_VERSION_MAJOR@";

    constexpr auto YADDNSC_VERSION_MINOR = "@YADDNSC_VERSION_MINOR@";

    constexpr auto YADDNSC_VERSION_PATCH = "@YADDNSC_VERSION_PATCH@";

    constexpr auto YADDNSC_RELEASE_INFO = "@YADDNSC_RELEASE_INFO@";

    constexpr auto get_full_version() {
        return "yaddnsc/@YADDNSC_VERSION_MAJOR@.@YADDNSC_VERSION_MINOR@.@YADDNSC_VERSION_PATCH@-@YADDNSC_RELEASE_INFO@";
    }

    constexpr auto get_short_version() {
        return "@YADDNSC_VERSION_MAJOR@.@YADDNSC_VERSION_MINOR@.@YADDNSC_VERSION_PATCH@-@YADDNSC_RELEASE_INFO@";
    }

    constexpr auto get_version() {
        return "@YADDNSC_VERSION_MAJOR@.@YADDNSC_VERSION_MINOR@.@YADDNSC_VERSION_PATCH@";
    }
}
#endif // YADDNSC_VERSION_H
